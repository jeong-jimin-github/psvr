<Application x:Class="PSVRPlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Dark theme -->
        <SolidColorBrush x:Key="Bg"       Color="#0D0D0F"/>
        <SolidColorBrush x:Key="Surface"  Color="#1A1A1F"/>
        <SolidColorBrush x:Key="Surface2" Color="#242429"/>
        <SolidColorBrush x:Key="Border"   Color="#2E2E38"/>
        <SolidColorBrush x:Key="Accent"   Color="#6C63FF"/>
        <SolidColorBrush x:Key="Text"     Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextDim"  Color="#8888AA"/>
        <SolidColorBrush x:Key="Green"    Color="#22C55E"/>
        <SolidColorBrush x:Key="Red"      Color="#EF4444"/>
        <SolidColorBrush x:Key="Yellow"   Color="#EAB308"/>
    </Application.Resources>
</Application>
